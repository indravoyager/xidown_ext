{
  "manifest_version": 3,
  "name": "xidown ext",
  "version": "1.3",
  "description": "Video downloader with full header cloning capabilities.",
  "permissions": [
    "activeTab",
    "storage",
    "cookies",
    "webRequest" 
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  
  "icons": {
    "16": "img/icon.png",
    "48": "img/icon.png",
    "128": "img/icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "img/icon.png"
  },

  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "run_at": "document_end"
    }
  ]
}